# copy to .env for local dev
PORT=3000
NODE_ENV=development

# signs the auth cookie — generate a long random string for production
JWT_SECRET=dev-only-change-me
ADMIN_TOKEN=dev-admin-token

# sqlite file location (gitignored; backed up to S3 in production)
DB_PATH=./data/quest.db

# path to the committed, hashed quest config
QUEST_CONFIG=../quest/quest.yaml
