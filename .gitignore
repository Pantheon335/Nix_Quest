# ------------------------
# Terraform core
# ------------------------

# Terraform working directories (recursively)
.terraform/

# State files
*.tfstate
*.tfstate.*

# Plan files
*.tfplan
plan.out

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# ------------------------
# Lock file (DO NOT IGNORE)
# ------------------------
!.terraform.lock.hcl



#--------------------------
# App core
#--------------------------

# dependencies & build
node_modules/
dist/

# runtime data (sqlite db; backed up to S3 separately)
data/
*.db
*.db-shm
*.db-wal

# secrets
.env
.env.*
!.env.example

# quest answers in clear text — never commit
quest/quest.plain.yaml
